{
    "name": "mohamedali/laravel-shipping",
    "description": "Laravel package for shipping companies integrations (Aramex, Sally, SMSA)",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Mohamedali\\LaravelShipping\\": "src/"
        }
    },
    "require": {
        "php": "^8.1",

        "another-vendor/package": "1.*"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mohamedali\\LaravelShipping\\ShippingServiceProvider"
            ]
        }
    }
}